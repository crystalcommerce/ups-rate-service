# UPS API Configuration (Required)
UPS_CLIENT_ID=your_ups_client_id_here
UPS_CLIENT_SECRET=your_ups_client_secret_here

# Environment Settings
UPS_ENVIRONMENT=sandbox  # or "production"

# API Configuration (Optional)
UPS_REQUEST_TIMEOUT=30
UPS_MAX_RETRIES=3

# Service Security (Optional)
AUTH_TOKEN=your_optional_bearer_token

# Server Configuration (Optional)
PORT=8000
WORKERS=1

# Logging (Optional)
LOG_LEVEL=INFO
DEBUG=false

FEDEX_CLIENT_ID=XXXXXXXXXXXXXXXX
FEDEX_CLIENT_SECRET=XXXXXXXXXXXXXXXX
FEDEX_ACCOUNT_NUMBER=123456789
FEDEX_BASE_URL="https://apis-sandbox.fedex.com" # Optional, fallback set to sandbox mode
